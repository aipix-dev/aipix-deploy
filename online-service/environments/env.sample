# --- Ports ---
LOCK_PORT=6444
API_PORT=80

# --- TLS (disabled by default, use external ingress) ---
LOCK_TLS=false
API_TLS=false
TLS_CERT_FILE=./fullchain.pem
TLS_KEY_FILE=./privkey.pem

# --- Database (MySQL/Percona) ---
DB_HOST=mysql-server
DB_PORT=3306
DB_NAME=locks
DB_USER=lockuser
DB_PASSWORD=LockPass123!

# --- Redis ---
REDIS_URL=redis-server:6379
REDIS_PASSWORD=
REDIS_DB=5

# --- MinIO (firmware storage) ---
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_USE_SSL=false

# --- Auth ---
JWT_SECRET=
OTA_AUTH_PASSWORD=D73aKrtv4eMp

# --- Logging ---
LOG_CHANNEL=stdout
SYSLOG_UDP_HOST=syslog.monitoring.svc
SYSLOG_UDP_PORT=5140
LOG_LEVEL=info

# --- Data retention ---
EVENTS_RETENTION_DAYS=30
LOGS_RETENTION_DAYS=7

# --- Public URL for shared links (optional, auto-detected if empty) ---
BASE_URL=

# --- Docker Compose only (not used by the app) ---
MYSQL_ROOT_PASSWORD=mysql
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
